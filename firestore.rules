rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (
          request.auth.token.email == "valtailubereats@gmail.com" ||
          request.auth.token.email == "generalsales2021@gmail.com" ||
          (
            exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
          )
        );
    }

    function isValidUser(data, userId) {
      return (!('uid' in data) || data.uid == userId) &&
             (!('name' in data) || (data.name is string && data.name.size() > 0 && data.name.size() < 100)) &&
             (!('email' in data) || data.email is string) &&
             (!('role' in data) || data.role in ['user', 'admin', 'moderator']) &&
             (!('phone' in data) || (data.phone is string && data.phone.size() <= 30)) &&
             (!('acceptedTerms' in data) || data.acceptedTerms is bool) &&
             (!('acceptedTermsAt' in data) || data.acceptedTermsAt is timestamp);
    }

    function isValidAd(data) {
      return data.keys().hasAll(['id', 'title', 'description', 'imageUrl', 'city', 'category', 'sellerId', 'sellerPhone', 'sellerName', 'status', 'createdAt']) &&
             data.id is string &&
             data.title is string &&
             data.description is string &&
             data.imageUrl is string &&
             data.city is string &&
             data.category is string &&
             data.sellerId == request.auth.uid &&
             data.sellerPhone is string &&
             data.sellerName is string &&
             data.status in ['pending', 'approved', 'rejected', 'expired', 'archived', 'sold'] &&
             (!('adStatus' in data) || data.adStatus in ['active', 'near_expiration', 'expired', 'archived', 'sold']) &&
             data.createdAt is timestamp;
    }

    function isValidSettings(data) {
      return data.keys().hasAll(['id', 'planDurations', 'expirationAction', 'warningDays']) &&
             data.planDurations is map &&
             data.expirationAction in ['archive', 'delete'] &&
             data.warningDays is number;
    }

    function isValidAdCounterUpdate() {
      let affected = request.resource.data.diff(resource.data).affectedKeys();
      return affected.hasOnly(['views', 'whatsappClicks']) &&
             (!affected.hasAny(['views']) || request.resource.data.views == resource.data.get('views', 0) + 1) &&
             (!affected.hasAny(['whatsappClicks']) || request.resource.data.whatsappClicks == resource.data.get('whatsappClicks', 0) + 1);
    }

    function isValidReview(data) {
      return data.keys().hasAll(['id', 'adId', 'adTitle', 'sellerId', 'buyerName', 'rating', 'comment', 'success', 'createdAt', 'buyerId', 'reviewerId', 'revieweeId']) &&
             data.id is string &&
             data.adId is string &&
             data.adTitle is string &&
             (!('adCategory' in data) || data.adCategory is string) &&
             data.sellerId is string &&
             data.buyerId is string &&
             data.buyerName is string &&
             data.rating is number && data.rating >= 1 && data.rating <= 5 &&
             data.comment is string && data.comment.size() <= 1000 &&
             data.success is bool &&
             data.reviewerId is string &&
             data.revieweeId is string &&
             data.sellerId != data.buyerId &&
             data.createdAt is timestamp;
    }

    function isValidRatingUpdate() {
      let affected = request.resource.data.diff(resource.data).affectedKeys();
      return affected.hasOnly(['ratingAverage', 'ratingCount']) &&
             request.resource.data.ratingCount == resource.data.get('ratingCount', 0) + 1;
    }

    function isValidSuggestion(data) {
      return data.keys().hasAll(['name', 'email', 'message', 'status', 'createdAt']) &&
             data.name is string &&
             data.email is string &&
             data.message is string &&
             data.status == 'new' &&
             data.createdAt is timestamp;
    }

    function isValidSellerPublicProfile(data) {
      return data.keys().hasAll(['displayName', 'country', 'createdAt', 'updatedAt']) &&
             data.displayName is string &&
             data.country is string &&
             data.createdAt is timestamp &&
             data.updatedAt is timestamp;
    }

    match /settings/{settingsId} {
      allow read: if true;
      allow write: if isValidSettings(request.resource.data) && isAdmin();
    }

    match /users/{userId} {
      allow get: if isAuthenticated();
      allow list: if request.query.limit == 0 || isAdmin();
      allow create: if isOwner(userId);
      allow update: if
        (isOwner(userId) && isValidUser(request.resource.data, userId)) ||
        (isAuthenticated() && isValidRatingUpdate()) ||
        (isAdmin() && isValidUser(request.resource.data, userId));
    }

    match /sellerPublicProfiles/{userId} {
      allow read: if true;
      allow create: if isOwner(userId) && isValidSellerPublicProfile(request.resource.data);
      allow update: if isOwner(userId) && isValidSellerPublicProfile(request.resource.data);
    }

    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() &&
                    request.resource.data.userId is string &&
                    request.resource.data.read == false;
      allow update: if isAdmin() || (
        isAuthenticated() &&
        resource.data.userId == request.auth.uid &&
        request.resource.data.userId == resource.data.userId &&
        request.resource.data.read == true
      );
      allow delete: if isAdmin();
    }

    match /ads/{adId} {
      allow read: if resource.data.status == 'approved' ||
                    (
                      isAuthenticated() &&
                      (
                        resource.data.sellerId == request.auth.uid ||
                        resource.data.get('buyerId', '') == request.auth.uid ||
                        isAdmin()
                      )
                    );

      allow create: if isAuthenticated() &&
                    isValidAd(request.resource.data) &&
                    request.resource.data.status == 'pending';

      allow update: if (
        (resource.data.status == 'approved' && isValidAdCounterUpdate()) ||

        (
          isAuthenticated() &&
          resource.data.sellerId == request.auth.uid &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['status', 'adStatus', 'buyerId', 'buyerName', 'soldAt', 'updatedAt']) &&
          request.resource.data.status == 'approved' &&
          request.resource.data.adStatus == 'sold' &&
          request.resource.data.buyerId is string &&
          request.resource.data.buyerName is string &&
          request.resource.data.soldAt is timestamp &&
          request.resource.data.updatedAt is timestamp
        ) ||

        (
          isAuthenticated() &&
          resource.data.sellerId == request.auth.uid &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['status', 'adStatus', 'updatedAt']) &&
          request.resource.data.status == 'approved' &&
          request.resource.data.adStatus == 'active'
        ) ||

        isAdmin()
      );

      allow delete: if isAuthenticated() &&
                    (resource.data.sellerId == request.auth.uid || isAdmin());
    }

    match /favorites/{favoriteId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    match /metrics/{metricId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /reports/{reportId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /referrals/{referralId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.referredUserId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /adInterests/{interestId} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated();
      allow delete: if isAdmin();
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isAuthenticated() &&
                    isValidReview(request.resource.data) &&
                    request.resource.data.reviewerId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /suggestions/{suggestionId} {
      allow read: if isAdmin();
      allow create: if isValidSuggestion(request.resource.data);
      allow update: if request.resource.data.status in ['new', 'reviewed', 'archived'] &&
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']) &&
                    isAdmin();
      allow delete: if isAdmin();
    }
  }
}