rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: /users/{userId}
    // Document ID: userId (UID from Auth)
    // Fields:
    //   - uid: string (required) - UID from Auth
    //   - name: string (required) - User's name
    //   - email: string (required) - User's email
    //   - phone: string (required) - User's phone number
    //   - role: string (required) - 'user' or 'admin'
    //   - acceptedTerms: boolean (required) - Whether user accepted terms
    //   - acceptedTermsAt: timestamp (required) - When user accepted terms
    //
    // Collection: /ads/{adId}
    // Document ID: adId (Randomly generated)
    // Fields:
    //   - id: string (required) - Ad ID
    //   - title: string (required) - Ad title
    //   - description: string (required) - Ad description
    //   - price: number (optional) - Ad price
    //   - imageUrl: string (required) - Ad image URL (primary)
    //   - images: list (optional) - List of all image URLs
    //   - city: string (required) - Ad city
    //   - category: string (required) - Ad category
    //   - sellerId: string (required) - Seller's UID
    //   - sellerPhone: string (required) - Seller's phone
    //   - sellerName: string (required) - Seller's name
    //   - status: string (required) - 'pending', 'approved', 'rejected'
    //   - createdAt: timestamp (required) - Ad creation time
    //
    // Collection: /settings/{settingsId}
    // Document ID: 'global'
    // Fields:
    //   - planDurations: map (required) - {free, intermediate, premium}
    //   - maxImages: map (required) - {free, intermediate, premium}
    //   - expirationAction: string (required) - 'archive' or 'delete'
    //   - warningDays: number (required) - Days before expiration to warn
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (
          request.auth.token.email == "valtailubereats@gmail.com" ||
          request.auth.token.email == "generalsales2021@gmail.com" ||
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
        );
    }

    function isValidUser(data, userId) {
      return (!('uid' in data) || data.uid == userId) &&
             (!('name' in data) || (data.name is string && data.name.size() > 0 && data.name.size() < 100)) &&
             (!('email' in data) || (data.email is string)) &&
             (!('role' in data) || (data.role in ['user', 'admin', 'moderator'])) &&
             (!('phone' in data) || (data.phone is string && data.phone.size() <= 30)) &&
             (!('acceptedTerms' in data) || (data.acceptedTerms is bool)) &&
             (!('acceptedTermsAt' in data) || (data.acceptedTermsAt is timestamp));
    }

    function isValidAd(data) {
      return data.keys().hasAll(['id', 'title', 'description', 'imageUrl', 'city', 'category', 'sellerId', 'sellerPhone', 'sellerName', 'status', 'createdAt']) &&
             data.id is string && data.id.size() > 0 && data.id.size() < 100 &&
             data.title is string && data.title.size() > 0 && data.title.size() < 150 &&
             data.description is string && data.description.size() > 0 && data.description.size() < 5000 &&
             (!('price' in data) || data.price is number) &&
             data.imageUrl is string && data.imageUrl.size() > 0 && data.imageUrl.size() < 1100000 &&
             (!('images' in data) || (data.images is list && data.images.size() <= 20)) &&
             data.city is string && data.city.size() > 0 && data.city.size() < 100 &&
             data.category is string && data.category.size() > 0 && data.category.size() < 100 &&
             data.sellerId == request.auth.uid &&
             data.sellerPhone is string && data.sellerPhone.size() > 0 && data.sellerPhone.size() < 40 &&
             data.sellerName is string && data.sellerName.size() > 0 && data.sellerName.size() < 100 &&
             data.status in ['pending', 'approved', 'rejected', 'expired', 'archived', 'sold'] &&
             (!('adStatus' in data) || data.adStatus in ['active', 'near_expiration', 'expired', 'archived', 'sold']) &&
             (!('plan' in data) || data.plan in ['free', 'intermediate', 'premium']) &&
             (!('contactEmail' in data) || data.contactEmail is string) &&
             (!('externalUrl' in data) || data.externalUrl is string) &&
             data.createdAt is timestamp;
    }

    function isValidSettings(data) {
      return data.keys().hasAll(['id', 'planDurations', 'expirationAction', 'warningDays']) &&
             data.planDurations is map &&
             (!('maxImages' in data) || data.maxImages is map) &&
             data.expirationAction in ['archive', 'delete'] &&
             data.warningDays is number;
    }

    function isValidAdCounterUpdate() {
      // Allow incrementing views or whatsappClicks by exactly 1
      // Ensure NO other fields are modified
      let affected = request.resource.data.diff(resource.data).affectedKeys();
      return affected.hasOnly(['views', 'whatsappClicks']) &&
             (!('views' in affected) || request.resource.data.views == resource.data.get('views', 0) + 1) &&
             (!('whatsappClicks' in affected) || request.resource.data.whatsappClicks == resource.data.get('whatsappClicks', 0) + 1);
    }

    function isValidReview(data) {
      return data.keys().hasAll(['id', 'adId', 'adTitle', 'sellerId', 'buyerName', 'rating', 'comment', 'success', 'createdAt']) &&
             data.id is string &&
             data.adId is string &&
             data.sellerId is string &&
             data.rating is number && data.rating >= 1 && data.rating <= 5 &&
             data.comment is string && data.comment.size() < 1000 &&
             data.success is bool &&
             data.createdAt is timestamp;
    }

    function isValidRatingUpdate() {
      // Allow updating ratingAverage and ratingCount
      let affected = request.resource.data.diff(resource.data).affectedKeys();
      return affected.hasOnly(['ratingAverage', 'ratingCount']) &&
             request.resource.data.ratingCount == resource.data.get('ratingCount', 0) + 1;
    }

    function isValidSuggestion(data) {
      return data.keys().hasAll(['name', 'email', 'message', 'status', 'createdAt']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.email is string && data.email.size() > 0 && data.email.size() < 100 &&
             data.message is string && data.message.size() > 0 && data.message.size() < 5000 &&
             data.status == 'new' &&
             data.createdAt is timestamp;
    }

    // Rules
    match /settings/{settingsId} {
      allow read: if true;
      allow write: if isAdmin() && isValidSettings(request.resource.data);
    }

    match /users/{userId} {
      allow get: if isAuthenticated();
      allow list: if isAdmin() || 
                    (isAuthenticated() && 
                     exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
                     get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'moderator') || 
                    request.query.limit == 0;
      allow create: if isOwner(userId) && 
                      (
                        !('role' in request.resource.data) || 
                        request.resource.data.role == 'user' || 
                        request.auth.token.email in ["valtailubereats@gmail.com", "generalsales2021@gmail.com"]
                      );
      allow update: if (isAdmin() && isValidUser(request.resource.data, userId)) || (isOwner(userId) && 
                      (
                        isValidUser(request.resource.data, userId) && 
                        request.resource.data.acceptedTerms == resource.data.acceptedTerms &&
                        request.resource.data.acceptedTermsAt == resource.data.acceptedTermsAt &&
                        (
                          !('role' in request.resource.data) || 
                          !('role' in resource.data) || 
                          request.resource.data.role == resource.data.role
                        )
                      )) || (isAuthenticated() && isValidRatingUpdate());
    }

    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow write: if isAdmin();
    }

    match /ads/{adId} {
      // Allow reading approved ads to everyone
      allow read: if resource.data.status == 'approved';
      
      // Allow owners to read their own ads
      allow read: if isAuthenticated() && resource.data.sellerId == request.auth.uid;
      
      // Allow admins to read everything
      allow read: if isAdmin();
      
      allow create: if isAuthenticated() && isValidAd(request.resource.data) && request.resource.data.status == 'pending';
      allow update: if (
        (resource.data.status == 'approved' && isValidAdCounterUpdate()) ||
        (isAuthenticated() && (
          (resource.data.sellerId == request.auth.uid && 
           (
             (resource.data.status == 'pending' && isValidAd(request.resource.data)) ||
             (isValidAd(request.resource.data) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isFeatured', 'featuredUntil']))
           )
          ) ||
          isAdmin()
        ))
      );
      allow delete: if isAuthenticated() && (resource.data.sellerId == request.auth.uid || isAdmin());
    }

    match /favorites/{favoriteId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    match /metrics/{metricId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /reports/{reportId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /referrals/{referralId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.referredUserId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidReview(request.resource.data) && request.resource.data.buyerId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /suggestions/{suggestionId} {
      allow read: if isAdmin();
      allow create: if isValidSuggestion(request.resource.data);
      allow update: if isAdmin() && 
                    request.resource.data.status in ['new', 'reviewed', 'archived'] && 
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']);
      allow delete: if isAdmin();
    }
  }
}
